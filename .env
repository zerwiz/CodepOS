# Team Configuration
TEAM_SETUP=true
TEAM_BRAND=true
TEAM_UI_GEN_A=true
TEAM_VALIDATION_A=true
TEAM_VALIDATION_B=true
TEAM_VALIDATION_C=true

# Variable Injection
UI_SCHEME_PATH=apps/infinite-ui/src/schemas
BRANDING_PATH=apps/branding/src
ARCHITECTURE_PATH=apps/infinite-ui/src/schemas/trees.schema.ts

# Agent Metadata Directories
AGENT_MDS_PATH=.pi/multi-team/agents
AGENT_REF_PATH=.pi/multi-team/agents/ref

# Project Configuration
CODEPOS_PROJECT_ROOT=CodepOS
PI_CLI_PATH=/home/zerwiz/.npm-global/bin/pi
PI_VERSION=0.70.2

# Team Priority
TEAM_SETUP_PRIORITY=1
TEAM_BRAND_PRIORITY=2
TEAM_UI_GEN_PRIORITY=3
TEAM_VALIDATION_PRIORITY=4

# Session State
SESSIONS_ENABLED=true
HISTORY_ENABLED=true
ARTIFACTS_ENABLED=true

# Security
SECURITY_SANDBOX=true
SECURITY_AUTH_METHOD=bearer
SECURITY_TOKEN_EXPIRY=3600
SECURITY_ENCRYPTION=aes-256

# API Configuration
API_URL=https://api.codepos.com
API_CACHE_TTL=300

# Validation Configuration
VALIDATION_STAGE_A=qa_tests
VALIDATION_STAGE_B=automated-tests
VALIDATION_STAGE_C=style-guidelines
VALIDATION_TIMEOUT=30
VALIDATION_SANDBOX=true

# Schema Paths
SCHEMAS_TREE=apps/infinite-ui/src/schemas/trees.schema.ts
SCHEMAS_UI=apps/infinite-ui/src/schemas/ui.schema.ts
SCHEMAS_VALIDATION=apps/infinite-ui/src/schemas/validation.schema.ts

# Enable Teams
ENABLE_SETUP=true
ENABLE_UI_GEN=true
ENABLE_VALIDATION_A=true
ENABLE_VALIDATION_B=true
ENABLE_VALIDATION_C=true

# Status
ENVIRONMENT_STATUS=active
LAST_CHECK=2024-01-01T00:00:00Z
