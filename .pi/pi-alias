#!/bin/bash

# Pi alias for harness
if [ -f justfile ]; then
  # Check if extensions loaded
  count=$(ls .pi/teams 2>/dev/null | wc -l)
  
  if [ $count -gt 0 ]; then
    echo ""
    echo "╔═══════════════════════════════════════════════════════════╗"
    echo "║    🚀 CODEPOS MULTI-AGENT ORCHESTRATOR                      ║"
    echo "╚═══════════════════════════════════════════════════════════╝"
    echo ""
    
    # Show extension status
    echo "📦 Extensions:"
    for dir in .pi/teams/*/; do
      name=$(basename $dir)
      if [ -f "$dir/index.mjs" ]; then
        echo "  ✅ $name"
      fi
    done
    
    echo ""
    echo "⚙️  Orchestrator: Active"
    echo "🛡️  Security: Enabled"
    echo ""
    echo "Run commands:"
    echo "  just orchestrate  - Run all agents"
    echo "  just design       - UI/UX"
    echo "  just testing      - QA"
    echo "  just api-backend  - API"
    echo ""
  else
    echo "ℹ️  Extensions not loaded yet. Run: just orchestrate"
  fi
  
fi
